//@version=5
indicator("CVR-CA USCS reader", overlay=true, max_labels_count=200)

//-----------------------------------------------------------------------------
// helpers
//-----------------------------------------------------------------------------

safe_div(numerator, denominator, fallback) =>
    not na(numerator) and not na(denominator) and denominator != 0.0 ? numerator / denominator : fallback

clamp_value(value, min_value, max_value) =>
    math.min(math.max(value, min_value), max_value)

state_color_from_label(label_text) =>
    label_text == "UP" ? color.new(color.lime, 0) :
     label_text == "DOWN" ? color.new(color.red, 0) :
     color.new(color.orange, 0)

reversal_color_from_label(label_text) =>
    label_text == "Stable" ? color.new(color.lime, 0) :
     label_text == "Fatigue" ? color.new(color.yellow, 0) :
     label_text == "Warning" ? color.new(color.orange, 0) :
     color.new(color.red, 0)

pressure_color_from_state(label_text) =>
    label_text == "CALM" ? color.new(color.lime, 0) :
     label_text == "ELEVATED" ? color.new(color.orange, 0) :
     color.new(color.red, 0)

margin_color_from_state(label_text) =>
    label_text == "SAFE" ? color.new(color.lime, 0) :
     label_text == "THIN" ? color.new(color.orange, 0) :
     color.new(color.red, 0)

radar_color_from_state(label_text) =>
    label_text == "READY" ? color.new(color.lime, 0) :
     label_text == "MONITOR" ? color.new(color.orange, 0) :
     color.new(color.red, 0)

market_phase_color_from_label(label_text) =>
    label_text == "CONFIRMED_UP" ? color.new(color.lime, 0) :
     label_text == "EARLY_UP" ? color.new(color.aqua, 0) :
     label_text == "BASE_BUILDING" ? color.new(color.teal, 0) :
     label_text == "BEARISH_REBOUND" ? color.new(color.orange, 0) :
     color.new(color.red, 0)

//-----------------------------------------------------------------------------
// inputs
//-----------------------------------------------------------------------------

group_inputs = "inputs"
struct_N = input.float(3.0, "struct_N", minval=0.1, step=0.1, group=group_inputs)
alpha_u = input.float(0.45, "alpha_u", minval=0.01, step=0.01, group=group_inputs)
alpha_d = input.float(0.30, "alpha_d", minval=0.01, step=0.01, group=group_inputs)
fee_rate = input.float(0.0010, "fee_rate", minval=0.0, step=0.0001, group=group_inputs)
slippage_rate = input.float(0.0005, "slippage_rate", minval=0.0, step=0.0001, group=group_inputs)
spread_proxy_bps = input.float(6.0, "spread_proxy_bps", minval=0.0, step=0.1, group=group_inputs)
use_custom_sigma = input.bool(true, "use_custom_sigma", group=group_inputs)
sigma_alpha = input.float(0.20, "sigma_alpha", minval=0.01, maxval=1.0, step=0.01, group=group_inputs)
sigma_w_ewtr = input.float(0.60, "sigma_w_ewtr", minval=0.0, maxval=1.0, step=0.05, group=group_inputs)
sigma_w_realized = input.float(0.40, "sigma_w_realized", minval=0.0, maxval=1.0, step=0.05, group=group_inputs)
use_dynamic_l = input.bool(true, "use_dynamic_l", group=group_inputs)
regime_gain_up = input.float(1.15, "regime_gain_up", minval=0.1, step=0.05, group=group_inputs)
regime_gain_neutral = input.float(1.00, "regime_gain_neutral", minval=0.1, step=0.05, group=group_inputs)
regime_gain_down = input.float(0.85, "regime_gain_down", minval=0.1, step=0.05, group=group_inputs)
rs_gain_k = input.float(0.20, "rs_gain_k", minval=0.0, step=0.01, group=group_inputs)
rs_gain_scale = input.float(0.75, "rs_gain_scale", minval=0.01, step=0.05, group=group_inputs)
dynamic_l_pair_mult = input.float(1.00, "dynamic_l_pair_mult", minval=0.1, step=0.05, group=group_inputs)
use_uscs_layer = input.bool(true, "use_uscs_layer", group=group_inputs)
uscs_theta_gain_k = input.float(0.15, "uscs_theta_gain_k", minval=0.0, step=0.01, group=group_inputs)
uscs_theta_scale = input.float(0.01, "uscs_theta_scale", minval=0.0001, step=0.0001, group=group_inputs)
uscs_heat_gain_k = input.float(0.15, "uscs_heat_gain_k", minval=0.0, step=0.01, group=group_inputs)
uscs_heat_ref = input.float(1.00, "uscs_heat_ref", minval=0.01, step=0.05, group=group_inputs)
uscs_g_min = input.float(0.80, "uscs_g_min", minval=0.1, step=0.05, group=group_inputs)
uscs_g_max = input.float(1.20, "uscs_g_max", minval=0.1, step=0.05, group=group_inputs)
q_soft = input.float(0.20, "q_soft", minval=0.0, step=0.01, group=group_inputs)
q_hard = input.float(0.35, "q_hard", minval=0.0, step=0.01, group=group_inputs)
trend_lookback = input.int(21, "trend lookback", minval=5, group=group_inputs)
reversal_lookback = input.int(12, "reversal lookback", minval=2, group=group_inputs)
trend_up_enter_threshold = input.float(0.35, "trend_up_enter_threshold", step=0.01, group=group_inputs)
trend_up_exit_threshold = input.float(0.15, "trend_up_exit_threshold", step=0.01, group=group_inputs)
trend_down_enter_threshold = input.float(-0.35, "trend_down_enter_threshold", step=0.01, group=group_inputs)
trend_down_exit_threshold = input.float(-0.15, "trend_down_exit_threshold", step=0.01, group=group_inputs)
trend_confirm_bars = input.int(3, "trend_confirm_bars", minval=1, group=group_inputs)
show_table = input.bool(true, "show_table", group=group_inputs)
show_bg = input.bool(true, "show_bg", group=group_inputs)
show_labels = input.bool(true, "show_labels", group=group_inputs)
show_dashboard_lanes = input.bool(true, "show_dashboard_lanes", group=group_inputs)
show_ma_bundle = input.bool(true, "show_ma_bundle", group=group_inputs)
ma_short_length = input.int(20, "ma short length", minval=2, group=group_inputs)
ma_mid_length = input.int(50, "ma mid length", minval=3, group=group_inputs)
ma_long_length = input.int(200, "ma long length", minval=5, group=group_inputs)
show_macd_signals = input.bool(false, "show_macd_signals", group=group_inputs)

sigma_length = trend_lookback
short_length = int(math.max(2.0, math.round(trend_lookback / 3.0)))

//-----------------------------------------------------------------------------
// sigma engine
//-----------------------------------------------------------------------------

TR = ta.tr(true)
ATR_raw = ta.atr(sigma_length)
ewtr_alpha = 2.0 / (sigma_alpha * sigma_length + 1.0)
var float EWTR = na
EWTR := na(EWTR[1]) ? TR : EWTR[1] + ewtr_alpha * (TR - EWTR[1])
log_return = math.log(safe_div(close, close[1], 1.0))
realized_vol_scaled = ta.stdev(log_return, sigma_length) * close
sigma_eff = sigma_w_ewtr * EWTR + sigma_w_realized * realized_vol_scaled
atr_safe = math.max(nz(ATR_raw, syminfo.mintick), syminfo.mintick)
sigma_floor = math.max(syminfo.mintick, atr_safe * 0.0001)
sigma_used = math.max(use_custom_sigma ? sigma_eff : ATR_raw, sigma_floor)
sigma_baseline = math.max(ta.ema(sigma_used, sigma_length), sigma_floor)
SigmaRatio = safe_div(sigma_used, sigma_baseline, 1.0)
SigmaSlope = sigma_used - nz(sigma_used[1], sigma_used)
sigma_expanding = SigmaRatio > 1.0 and SigmaSlope > 0.0
sigma_compressing = SigmaRatio < 1.0 and SigmaSlope < 0.0
SigmaEffRatio = safe_div(sigma_eff, sigma_baseline, 1.0)
ATRRatio = safe_div(atr_safe, sigma_baseline, 1.0)
SigmaState = sigma_expanding ? "EXPANDING" : sigma_compressing ? "COMPRESSING" : "BALANCED"

//-----------------------------------------------------------------------------
// cost proxy
//-----------------------------------------------------------------------------

fee_roundtrip = close * fee_rate * 2.0
spread_proxy = close * spread_proxy_bps / 10000.0
slippage_proxy = close * slippage_rate * 2.0
Cost_proxy = fee_roundtrip + spread_proxy + slippage_proxy

//-----------------------------------------------------------------------------
// CVR core
//-----------------------------------------------------------------------------

L_base = safe_div(alpha_u, alpha_d, 1.0) / struct_N
CVR_ratio = safe_div(Cost_proxy, sigma_used, 0.0)
m = L_base - CVR_ratio
E = L_base * sigma_used - Cost_proxy
Q_ratio = safe_div(spread_proxy, math.max(atr_safe, sigma_floor), 0.0)
Q_state = Q_ratio > q_hard ? "HARD" : Q_ratio > q_soft ? "SOFT" : "OK"

//-----------------------------------------------------------------------------
// overlay context
//-----------------------------------------------------------------------------

ma_short = ta.ema(close, ma_short_length)
ma_mid = ta.ema(close, ma_mid_length)
ma_long = ta.ema(close, ma_long_length)
ma_stack_score = (ma_short > ma_mid ? 1.0 : ma_short < ma_mid ? -1.0 : 0.0) + (ma_mid > ma_long ? 1.0 : ma_mid < ma_long ? -1.0 : 0.0)
ma_stack_norm = ma_stack_score / 2.0
MAStackLabel = ma_stack_score >= 2.0 ? "Bullish" : ma_stack_score <= -2.0 ? "Bearish" : "Mixed"
[macd_line, macd_signal, macd_hist] = ta.macd(close, 12, 26, 9)
macd_norm = clamp_value(safe_div(macd_hist, sigma_used, 0.0), -1.0, 1.0)
macd_cross_up = ta.crossover(macd_line, macd_signal)
macd_cross_down = ta.crossunder(macd_line, macd_signal)
MACDLabel = macd_line > macd_signal and macd_hist >= 0.0 ? "Bullish" : macd_line < macd_signal and macd_hist <= 0.0 ? "Bearish" : "Transition"

//-----------------------------------------------------------------------------
// dynamic gains
//-----------------------------------------------------------------------------

ema_4h = request.security(syminfo.tickerid, "240", ta.ema(close, trend_lookback))
ema_4h_prev = request.security(syminfo.tickerid, "240", ta.ema(close, trend_lookback)[1])
ema_1d = request.security(syminfo.tickerid, "D", ta.ema(close, trend_lookback))
ema_1d_prev = request.security(syminfo.tickerid, "D", ta.ema(close, trend_lookback)[1])
ema_slope_4h = ema_4h - ema_4h_prev
ema_slope_1d = ema_1d - ema_1d_prev
theta_4h = safe_div(ema_slope_4h, math.max(math.abs(ema_4h_prev), syminfo.mintick), 0.0)
theta_1d = safe_div(ema_slope_1d, math.max(math.abs(ema_1d_prev), syminfo.mintick), 0.0)
rsi_value = ta.rsi(close, trend_lookback)
rsi_score = clamp_value((rsi_value - 50.0) / 50.0, -1.0, 1.0)
theta_score = clamp_value(safe_div(theta_4h + theta_1d, 2.0 * uscs_theta_scale, 0.0), -1.0, 1.0)
RS_score = clamp_value(rsi_score * 0.65 + theta_score * 0.35, -1.0, 1.0)
trend_component_4h = clamp_value(safe_div(ema_slope_4h, sigma_used, 0.0), -2.0, 2.0)
trend_component_1d = clamp_value(safe_div(ema_slope_1d, sigma_used, 0.0), -2.0, 2.0)
TrendScore = clamp_value(trend_component_4h * 0.35 + trend_component_1d * 0.25 + RS_score * 0.20 + ma_stack_norm * 0.10 + macd_norm * 0.10, -2.0, 2.0)
TrendLabel = TrendScore > 0.25 ? "UP" : TrendScore < -0.25 ? "DOWN" : "NEUTRAL"
G_regime = TrendLabel == "UP" ? regime_gain_up : TrendLabel == "DOWN" ? regime_gain_down : regime_gain_neutral
G_rs = clamp_value(1.0 + rs_gain_k * RS_score * rs_gain_scale, 0.5, 1.5)
G_pair = dynamic_l_pair_mult
L_pre_uscs = L_base * (use_dynamic_l ? G_regime * G_rs * G_pair : 1.0)
CostKillRisk_pre = safe_div(CVR_ratio, math.max(L_pre_uscs, syminfo.mintick), 0.0)
uscs_heat = math.max(0.0, SigmaRatio - 1.0) + math.max(0.0, Q_ratio - q_soft) + math.max(0.0, CostKillRisk_pre - 1.0)
theta_state = clamp_value(safe_div(theta_4h + theta_1d, 2.0 * uscs_theta_scale, 0.0), -1.0, 1.0)
G_theta = clamp_value(1.0 + uscs_theta_gain_k * theta_state, uscs_g_min, uscs_g_max)
heat_over = math.max(0.0, safe_div(uscs_heat - uscs_heat_ref, uscs_heat_ref, 0.0))
G_heat = clamp_value(1.0 - uscs_heat_gain_k * heat_over, uscs_g_min, uscs_g_max)
G_uscs = use_uscs_layer ? clamp_value(G_theta * G_heat, uscs_g_min, uscs_g_max) : 1.0
L_eff = L_base * (use_dynamic_l ? G_regime * G_rs * G_pair : 1.0) * G_uscs
m_eff = L_eff - CVR_ratio
E_eff = L_eff * sigma_used - Cost_proxy

//-----------------------------------------------------------------------------
// trend direction
//-----------------------------------------------------------------------------

prevTrendLabel = bar_index > 0 ? TrendLabel[1] : TrendLabel
trend_changed = TrendLabel != prevTrendLabel
trend_up = TrendLabel == "UP"
trend_down = TrendLabel == "DOWN"
bull_structure = close > ema_4h and ema_4h > ema_1d and ema_slope_4h > 0.0 and ema_slope_1d > 0.0
bear_structure = close < ema_4h and ema_4h < ema_1d and ema_slope_4h < 0.0 and ema_slope_1d < 0.0

var string TrendState = "NEUTRAL"
prevTrendState = TrendState
if TrendState == "NEUTRAL"
    TrendState := TrendScore >= trend_up_enter_threshold ? "UP" : TrendScore <= trend_down_enter_threshold ? "DOWN" : "NEUTRAL"
else if TrendState == "UP"
    TrendState := TrendScore < trend_up_exit_threshold ? "NEUTRAL" : "UP"
else
    TrendState := TrendScore > trend_down_exit_threshold ? "NEUTRAL" : "DOWN"
TrendStateChanged = TrendState != prevTrendState

//-----------------------------------------------------------------------------
// reversal precursor
//-----------------------------------------------------------------------------

ema_short = ta.ema(close, short_length)
short_slope = ema_short - nz(ema_short[1], ema_short)
MarginDrift = m_eff - nz(m_eff[reversal_lookback], m_eff)
m_eff_worsening = clamp_value(safe_div(-MarginDrift, math.max(math.abs(L_eff), syminfo.mintick), 0.0), 0.0, 1.0)
rs_drift = RS_score - nz(RS_score[reversal_lookback], RS_score)
rs_worsening = clamp_value(-rs_drift, 0.0, 1.0)
q_worsening = clamp_value(safe_div(Q_ratio - q_soft, math.max(q_hard - q_soft, syminfo.mintick), 0.0), 0.0, 1.0)
short_slope_slowing = clamp_value(safe_div(nz(short_slope[reversal_lookback], short_slope) - short_slope, sigma_used, 0.0), 0.0, 1.0)
heat_worsening = clamp_value(safe_div(uscs_heat - uscs_heat_ref, math.max(uscs_heat_ref, 0.01), 0.0), 0.0, 1.0)
ReversalScore = clamp_value(m_eff_worsening * 0.30 + rs_worsening * 0.20 + q_worsening * 0.20 + short_slope_slowing * 0.15 + heat_worsening * 0.15, 0.0, 1.20)
ReversalLabel = ReversalScore >= 0.85 ? "FlipCandidate" : ReversalScore >= 0.60 ? "Warning" : ReversalScore >= 0.35 ? "Fatigue" : "Stable"

confirmed_up_condition = TrendState == "UP" and bull_structure and m_eff > 0.0 and Q_state == "OK"
var int confirmed_up_bars = 0
confirmed_up_bars := confirmed_up_condition ? confirmed_up_bars + 1 : 0

confirmed_up_ready = confirmed_up_bars >= trend_confirm_bars and ReversalLabel != "Warning" and ReversalLabel != "FlipCandidate"
down_continuation = TrendState == "DOWN" and bear_structure and (ReversalLabel == "Stable" or ReversalLabel == "Fatigue")
bearish_rebound = TrendState == "DOWN" and not bear_structure and short_slope > 0.0 and m_eff > 0.0
base_building = TrendState == "NEUTRAL" and m_eff > 0.0 and Q_state != "HARD"
early_up = TrendState == "UP" and bull_structure and confirmed_up_bars < trend_confirm_bars
confirmed_up_phase = TrendState == "UP" and bull_structure and confirmed_up_ready and Q_state == "OK" and m_eff > 0.0

MarketPhaseLabel = confirmed_up_phase ? "CONFIRMED_UP" :
 early_up ? "EARLY_UP" :
 down_continuation ? "DOWN_CONTINUATION" :
 bearish_rebound ? "BEARISH_REBOUND" :
 base_building ? "BASE_BUILDING" :
 TrendState == "UP" and bull_structure ? "EARLY_UP" :
 TrendState == "DOWN" and bear_structure ? "DOWN_CONTINUATION" :
 TrendState == "DOWN" ? "BEARISH_REBOUND" : "BASE_BUILDING"

trend_quality = TrendState == "UP" ? 1.0 : TrendState == "NEUTRAL" ? 0.45 : 0.10
structure_quality = bull_structure ? 1.0 : close > ema_4h ? 0.60 : 0.20
margin_quality = clamp_value(safe_div(m_eff, math.max(L_eff, syminfo.mintick), 0.0), 0.0, 1.0)
reversal_penalty = ReversalLabel == "Stable" ? 0.00 : ReversalLabel == "Fatigue" ? 0.15 : ReversalLabel == "Warning" ? 0.35 : 0.60
q_penalty = Q_state == "OK" ? 0.00 : Q_state == "SOFT" ? 0.20 : 0.50
RiseQualityScore = clamp_value(trend_quality * 0.30 + structure_quality * 0.25 + margin_quality * 0.25 + (confirmed_up_bars >= trend_confirm_bars ? 0.20 : 0.05) - reversal_penalty - q_penalty, 0.0, 1.0)

//-----------------------------------------------------------------------------
// plots
//-----------------------------------------------------------------------------

CostKillRisk = safe_div(CVR_ratio, math.max(L_eff, syminfo.mintick), 0.0)
cost_pressure_high = CostKillRisk > 1.0 or Q_ratio > q_hard
margin_thin = m_eff > 0.0 and m_eff <= L_eff * 0.15
margin_collapsing = m_eff <= 0.0 or MarginDrift < -0.15
ma_bull = ma_short > ma_mid and ma_mid > ma_long
ma_bear = ma_short < ma_mid and ma_mid < ma_long
macd_bull = macd_line > macd_signal and macd_hist >= 0.0
macd_bear = macd_line < macd_signal and macd_hist <= 0.0
alignment_bull = trend_up and ma_bull and macd_bull
alignment_bear = trend_down and ma_bear and macd_bear
PressureState = cost_pressure_high ? "HIGH" : Q_ratio > q_soft or CostKillRisk > 0.85 ? "ELEVATED" : "CALM"
MarginState = m_eff <= 0.0 ? "NEGATIVE" : margin_thin ? "THIN" : "SAFE"
RadarState = m_eff <= 0.0 ? "DEFENSIVE" : ReversalLabel == "FlipCandidate" or cost_pressure_high ? "DEFENSIVE" : alignment_bull and ReversalLabel == "Stable" ? "READY" : "MONITOR"
pressure_norm = clamp_value(CostKillRisk - 1.0, -0.75, 1.50)
q_pressure_norm = clamp_value(safe_div(Q_ratio - q_soft, math.max(q_hard - q_soft, 0.0001), 0.0), -0.75, 1.50)
heat_pressure_norm = clamp_value(safe_div(uscs_heat - uscs_heat_ref, math.max(uscs_heat_ref, 0.01), 0.0), -0.75, 1.50)
sigma_used_norm = clamp_value(SigmaRatio - 1.0, -1.50, 1.50)
sigma_eff_norm = clamp_value(SigmaEffRatio - 1.0, -1.50, 1.50)
atr_norm = clamp_value(ATRRatio - 1.0, -1.50, 1.50)

state_bg = m_eff > 0.0 and Q_ratio < q_soft and alignment_bull ? color.new(color.lime, 86) :
 m_eff > 0.0 and Q_ratio < q_soft ? color.new(color.teal, 86) :
 m_eff > 0.0 and Q_ratio >= q_soft ? color.new(color.orange, 87) :
 alignment_bear ? color.new(color.red, 80) : color.new(color.red, 86)
state_bar = m_eff > 0.0 and Q_ratio < q_soft and alignment_bull ? color.new(color.lime, 0) :
 m_eff > 0.0 and Q_ratio < q_soft ? color.new(color.teal, 0) :
 m_eff > 0.0 and Q_ratio >= q_soft ? color.new(color.orange, 0) :
 alignment_bear ? color.new(color.maroon, 0) : color.new(color.red, 0)

bgcolor(show_bg ? state_bg : na, title="State Background")
barcolor(show_bg ? state_bar : na, title="State Bars")

ma_short_plot = plot(show_ma_bundle ? ma_short : na, "MA short", color=color.new(color.aqua, 0), linewidth=2)
ma_mid_plot = plot(show_ma_bundle ? ma_mid : na, "MA mid", color=color.new(color.yellow, 0), linewidth=2)
plot(show_ma_bundle ? ma_long : na, "MA long", color=color.new(color.fuchsia, 0), linewidth=3)
fill(ma_short_plot, ma_mid_plot, color=ma_short >= ma_mid ? color.new(color.lime, 88) : color.new(color.red, 88), title="MA momentum cloud")

visual_lookback = math.max(trend_lookback * 3, 50)
visual_anchor = ta.lowest(low, visual_lookback) - atr_safe * 1.65
visual_step = math.max(atr_safe * 0.26, syminfo.mintick * 30.0)

m_lane = visual_anchor + visual_step * 6.0
sigma_lane = visual_anchor + visual_step * 4.7
pressure_lane = visual_anchor + visual_step * 3.4
trend_lane = visual_anchor + visual_step * 2.1
reversal_lane = visual_anchor + visual_step * 0.8

plot(show_dashboard_lanes ? m_lane : na, "m_eff baseline", color=color.new(color.silver, 75), linewidth=1, style=plot.style_linebr)
plot(show_dashboard_lanes ? sigma_lane : na, "SigmaRatio baseline", color=color.new(color.silver, 75), linewidth=1, style=plot.style_linebr)
plot(show_dashboard_lanes ? pressure_lane : na, "Pressure baseline", color=color.new(color.silver, 75), linewidth=1, style=plot.style_linebr)
plot(show_dashboard_lanes ? trend_lane : na, "TrendScore baseline", color=color.new(color.silver, 75), linewidth=1, style=plot.style_linebr)
plot(show_dashboard_lanes ? reversal_lane : na, "ReversalScore baseline", color=color.new(color.silver, 75), linewidth=1, style=plot.style_linebr)
plot(show_dashboard_lanes ? pressure_lane + visual_step : na, "Pressure hard guide", color=color.new(color.red, 85), linewidth=1, style=plot.style_linebr)
plot(show_dashboard_lanes ? reversal_lane + visual_step * 0.60 : na, "Reversal warning guide", color=color.new(color.orange, 85), linewidth=1, style=plot.style_linebr)

plot(show_dashboard_lanes ? m_lane + clamp_value(m, -2.0, 2.5) * visual_step : na, "m static", color=color.new(color.silver, 20), linewidth=1)
plot(show_dashboard_lanes ? m_lane + clamp_value(m_eff, -2.0, 2.5) * visual_step : na, "m_eff", color=m_eff >= 0.0 ? color.new(color.lime, 0) : color.new(color.red, 0), linewidth=3)
plot(show_dashboard_lanes ? sigma_lane + atr_norm * visual_step : na, "ATR ratio", color=color.new(color.white, 25), linewidth=1)
plot(show_dashboard_lanes ? sigma_lane + sigma_eff_norm * visual_step : na, "sigma_eff ratio", color=color.new(color.fuchsia, 15), linewidth=2)
plot(show_dashboard_lanes ? sigma_lane + sigma_used_norm * visual_step : na, "SigmaRatio", color=sigma_expanding ? color.new(color.orange, 0) : sigma_compressing ? color.new(color.aqua, 0) : color.new(color.blue, 0), linewidth=3)
plot(show_dashboard_lanes ? pressure_lane + heat_pressure_norm * visual_step : na, "Heat pressure", color=color.new(color.yellow, 10), linewidth=1)
plot(show_dashboard_lanes ? pressure_lane + q_pressure_norm * visual_step : na, "Q pressure", color=Q_ratio > q_hard ? color.new(color.red, 0) : Q_ratio > q_soft ? color.new(color.orange, 0) : color.new(color.aqua, 0), linewidth=2)
plot(show_dashboard_lanes ? pressure_lane + pressure_norm * visual_step : na, "CostKillRisk", color=cost_pressure_high ? color.new(color.red, 0) : color.new(color.orange, 0), linewidth=3)
plot(show_dashboard_lanes ? trend_lane + RS_score * visual_step : na, "RS_score", color=color.new(color.aqua, 25), linewidth=1)
plot(show_dashboard_lanes ? trend_lane + TrendScore * visual_step : na, "TrendScore", color=state_color_from_label(TrendLabel), linewidth=3)
plot(show_dashboard_lanes ? reversal_lane + heat_worsening * visual_step : na, "Heat worsening", color=color.new(color.yellow, 20), linewidth=1)
plot(show_dashboard_lanes ? reversal_lane + ReversalScore * visual_step : na, "ReversalScore", color=reversal_color_from_label(ReversalLabel), linewidth=3)

plot(show_dashboard_lanes ? m_lane : na, "m_eff zero guide", color=color.new(color.white, 90), linewidth=1, style=plot.style_circles)
plot(show_dashboard_lanes ? sigma_lane : na, "SigmaRatio one guide", color=color.new(color.white, 90), linewidth=1, style=plot.style_circles)
plot(show_dashboard_lanes ? pressure_lane : na, "Pressure calm guide", color=color.new(color.white, 90), linewidth=1, style=plot.style_circles)
plot(show_dashboard_lanes ? trend_lane : na, "Trend zero guide", color=color.new(color.white, 92), linewidth=1, style=plot.style_circles)

plotshape(show_labels and trend_changed and trend_up, title="Trend UP", style=shape.arrowup, location=location.belowbar, color=color.new(color.lime, 0), size=size.tiny, text="UP")
plotshape(show_labels and trend_changed and trend_down, title="Trend DOWN", style=shape.arrowdown, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny, text="DOWN")
plotshape(show_labels and ReversalLabel == "Warning", title="Reversal Warning", style=shape.triangleup, location=location.abovebar, color=color.new(color.orange, 0), size=size.tiny, text="WARN")
plotshape(show_labels and ReversalLabel == "FlipCandidate", title="Reversal FlipCandidate", style=shape.diamond, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny, text="FLIP")
plotshape(show_labels and show_macd_signals and macd_cross_up, title="MACD bullish cross", style=shape.circle, location=location.belowbar, color=color.new(color.aqua, 0), size=size.tiny, text="MACD+")
plotshape(show_labels and show_macd_signals and macd_cross_down, title="MACD bearish cross", style=shape.circle, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny, text="MACD-")

var label margin_status_label = na
var label sigma_status_label = na
var label pressure_status_label = na
var label trend_status_label = na
var label reversal_status_label = na

if barstate.islast
    label.delete(margin_status_label)
    label.delete(sigma_status_label)
    label.delete(pressure_status_label)
    label.delete(trend_status_label)
    label.delete(reversal_status_label)
    if show_labels and show_dashboard_lanes
        margin_status_label := label.new(bar_index, m_lane, "MARGIN " + MarginState + " | " + str.tostring(m_eff, "#.##"), xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_left, textcolor=color.white, color=color.new(margin_color_from_state(MarginState), 72), size=size.tiny)
        sigma_status_label := label.new(bar_index, sigma_lane, "SIGMA " + SigmaState + " | " + str.tostring(SigmaRatio, "#.##") + "x", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_left, textcolor=color.white, color=color.new(sigma_expanding ? color.orange : sigma_compressing ? color.aqua : color.blue, 72), size=size.tiny)
        pressure_status_label := label.new(bar_index, pressure_lane, "PRESS " + PressureState + " | Q " + Q_state, xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_left, textcolor=color.white, color=color.new(pressure_color_from_state(PressureState), 72), size=size.tiny)
        trend_status_label := label.new(bar_index, trend_lane, "RADAR " + RadarState + " | " + TrendLabel, xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_left, textcolor=color.white, color=color.new(radar_color_from_state(RadarState), 72), size=size.tiny)
        reversal_status_label := label.new(bar_index, reversal_lane, "REV " + ReversalLabel + " | " + MACDLabel, xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_left, textcolor=color.white, color=color.new(reversal_color_from_label(ReversalLabel), 72), size=size.tiny)

//-----------------------------------------------------------------------------
// table
//-----------------------------------------------------------------------------

var table summary_table = table.new(position.top_right, 2, 28, border_width=1)

if barstate.islast
    if show_table
        table.clear(summary_table, 0, 0, 1, 27)
        table.cell(summary_table, 0, 0, "Metric", text_color=color.white, bgcolor=color.new(color.black, 0))
        table.cell(summary_table, 1, 0, "Value", text_color=color.white, bgcolor=color.new(color.black, 0))
        table.cell(summary_table, 0, 1, "Radar")
        table.cell(summary_table, 1, 1, RadarState, text_color=radar_color_from_state(RadarState))
        table.cell(summary_table, 0, 2, "Sigma")
        table.cell(summary_table, 1, 2, SigmaState, text_color=sigma_expanding ? color.orange : sigma_compressing ? color.aqua : color.white)
        table.cell(summary_table, 0, 3, "Pressure")
        table.cell(summary_table, 1, 3, PressureState, text_color=pressure_color_from_state(PressureState))
        table.cell(summary_table, 0, 4, "Margin")
        table.cell(summary_table, 1, 4, MarginState, text_color=margin_color_from_state(MarginState))
        table.cell(summary_table, 0, 5, "Trend")
        table.cell(summary_table, 1, 5, TrendLabel, text_color=state_color_from_label(TrendLabel))
        table.cell(summary_table, 0, 6, "Reversal")
        table.cell(summary_table, 1, 6, ReversalLabel, text_color=reversal_color_from_label(ReversalLabel))
        table.cell(summary_table, 0, 7, "sigma_used")
        table.cell(summary_table, 1, 7, str.tostring(sigma_used, format.mintick))
        table.cell(summary_table, 0, 8, "ATR_raw")
        table.cell(summary_table, 1, 8, str.tostring(ATR_raw, format.mintick))
        table.cell(summary_table, 0, 9, "sigma_eff")
        table.cell(summary_table, 1, 9, str.tostring(sigma_eff, format.mintick))
        table.cell(summary_table, 0, 10, "SigmaRatio / Slope")
        table.cell(summary_table, 1, 10, str.tostring(SigmaRatio, "#.###") + " / " + str.tostring(SigmaSlope, format.mintick), text_color=sigma_expanding ? color.orange : sigma_compressing ? color.aqua : color.white)
        table.cell(summary_table, 0, 11, "Cost_proxy")
        table.cell(summary_table, 1, 11, str.tostring(Cost_proxy, format.mintick))
        table.cell(summary_table, 0, 12, "CVR_ratio")
        table.cell(summary_table, 1, 12, str.tostring(CVR_ratio, "#.###"))
        table.cell(summary_table, 0, 13, "L_base / L_eff")
        table.cell(summary_table, 1, 13, str.tostring(L_base, "#.###") + " / " + str.tostring(L_eff, "#.###"))
        table.cell(summary_table, 0, 14, "m / m_eff")
        table.cell(summary_table, 1, 14, str.tostring(m, "#.###") + " / " + str.tostring(m_eff, "#.###"), text_color=m_eff >= 0.0 ? color.lime : color.red)
        table.cell(summary_table, 0, 15, "MarginDrift")
        table.cell(summary_table, 1, 15, str.tostring(MarginDrift, "#.###"), text_color=margin_collapsing ? color.red : margin_thin ? color.orange : color.white)
        table.cell(summary_table, 0, 16, "CostKillRisk")
        table.cell(summary_table, 1, 16, str.tostring(CostKillRisk, "#.###"), text_color=cost_pressure_high ? color.red : color.white)
        table.cell(summary_table, 0, 17, "RS_score")
        table.cell(summary_table, 1, 17, str.tostring(RS_score, "#.###"))
        table.cell(summary_table, 0, 18, "Q_ratio")
        table.cell(summary_table, 1, 18, str.tostring(Q_ratio, "#.###") + " (" + Q_state + ")", text_color=Q_ratio > q_hard ? color.red : Q_ratio > q_soft ? color.orange : color.white)
        table.cell(summary_table, 0, 19, "MA stack")
        table.cell(summary_table, 1, 19, MAStackLabel, text_color=ma_bull ? color.lime : ma_bear ? color.red : color.orange)
        table.cell(summary_table, 0, 20, "MA short/mid/long")
        table.cell(summary_table, 1, 20, str.tostring(ma_short, format.mintick) + " / " + str.tostring(ma_mid, format.mintick) + " / " + str.tostring(ma_long, format.mintick))
        table.cell(summary_table, 0, 21, "MACD")
        table.cell(summary_table, 1, 21, MACDLabel, text_color=macd_bull ? color.lime : macd_bear ? color.red : color.orange)
        table.cell(summary_table, 0, 22, "MACD hist")
        table.cell(summary_table, 1, 22, str.tostring(macd_hist, format.mintick), text_color=macd_hist >= 0.0 ? color.lime : color.red)
        table.cell(summary_table, 0, 23, "TrendState")
        table.cell(summary_table, 1, 23, TrendState, text_color=state_color_from_label(TrendState))
        table.cell(summary_table, 0, 24, "MarketPhase")
        table.cell(summary_table, 1, 24, MarketPhaseLabel, text_color=market_phase_color_from_label(MarketPhaseLabel))
        table.cell(summary_table, 0, 25, "RiseQuality")
        table.cell(summary_table, 1, 25, str.tostring(RiseQualityScore, "#.###"), text_color=RiseQualityScore >= 0.70 ? color.lime : RiseQualityScore >= 0.50 ? color.orange : color.red)
        table.cell(summary_table, 0, 26, "bull_structure")
        table.cell(summary_table, 1, 26, bull_structure ? "true" : "false", text_color=bull_structure ? color.lime : color.orange)
        table.cell(summary_table, 0, 27, "confirmed_up_bars")
        table.cell(summary_table, 1, 27, str.tostring(confirmed_up_bars))
    else
        table.clear(summary_table, 0, 0, 1, 27)

//-----------------------------------------------------------------------------
// alerts
//-----------------------------------------------------------------------------

prevReversalLabel = bar_index > 0 ? ReversalLabel[1] : "Stable"
reversal_warning_enter = ReversalLabel == "Warning" and prevReversalLabel != "Warning"
reversal_flip_enter = ReversalLabel == "FlipCandidate" and prevReversalLabel != "FlipCandidate"
trend_up_warning = TrendLabel == "UP" and ReversalLabel == "Warning"
trend_down_warning = TrendLabel == "DOWN" and ReversalLabel == "Warning"
prevMarketPhaseLabel = bar_index > 0 ? MarketPhaseLabel[1] : MarketPhaseLabel
market_phase_bearish_rebound_enter = MarketPhaseLabel == "BEARISH_REBOUND" and prevMarketPhaseLabel != "BEARISH_REBOUND"
market_phase_confirmed_up_enter = MarketPhaseLabel == "CONFIRMED_UP" and prevMarketPhaseLabel != "CONFIRMED_UP"

alertcondition(trend_changed, "TrendLabel changes", "TrendLabel changed")
alertcondition(TrendStateChanged, "TrendState changes", "TrendState changed")
alertcondition(reversal_warning_enter, "ReversalLabel enters Warning", "ReversalLabel entered Warning")
alertcondition(reversal_flip_enter, "ReversalLabel enters FlipCandidate", "ReversalLabel entered FlipCandidate")
alertcondition(market_phase_bearish_rebound_enter, "MarketPhase enters BEARISH_REBOUND", "MarketPhaseLabel entered BEARISH_REBOUND")
alertcondition(market_phase_confirmed_up_enter, "MarketPhase enters CONFIRMED_UP", "MarketPhaseLabel entered CONFIRMED_UP")
alertcondition(ta.crossover(RiseQualityScore, 0.70), "RiseQualityScore crosses above 0.70", "RiseQualityScore crossed above 0.70")
alertcondition(ta.crossunder(RiseQualityScore, 0.50), "RiseQualityScore crosses below 0.50", "RiseQualityScore crossed below 0.50")
alertcondition(ta.crossunder(m_eff, 0.0), "m_eff crosses below 0", "m_eff crossed below 0")
alertcondition(ta.crossover(m_eff, 0.0), "m_eff crosses above 0", "m_eff crossed above 0")
alertcondition(ta.crossunder(SigmaRatio, 1.0), "SigmaRatio crosses below 1", "SigmaRatio crossed below 1")
alertcondition(CostKillRisk > 1.0, "CostKillRisk > 1", "CostKillRisk is above 1")
alertcondition(Q_ratio > q_soft, "Q_ratio > q_soft", "Q_ratio is above q_soft")
alertcondition(Q_ratio > q_hard, "Q_ratio > q_hard", "Q_ratio is above q_hard")
alertcondition(trend_up_warning, "Trend=UP and Reversal=Warning", "Trend is UP while Reversal is Warning")
alertcondition(trend_down_warning, "Trend=DOWN and Reversal=Warning", "Trend is DOWN while Reversal is Warning")
alertcondition(macd_cross_up, "MACD bullish cross", "MACD crossed above the signal line")
alertcondition(macd_cross_down, "MACD bearish cross", "MACD crossed below the signal line")
